<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>末日回响写作站</title>
    <link rel="shortcut icon" href="{{ url_for('static', filename='favicon.ico') }}">
    <style>
        :root {
            --bg: #fafbfc;
            --card-bg: #ffffff;
            --text: #1e1e2f;
            --border: #ddd;
            --primary: #0070f3;
            --primary-hover: #005bb5;
            --secondary: #6c757d;
            --secondary-hover: #5a6268;
            --shadow: rgba(0,0,0,0.05);
            --noti-bg: #ffffff;
            --comment-highlight: rgba(0,112,243,0.1);
            --search-bg: #f0f2f5;
            --search-glow: rgba(0,112,243,0.1);
            --bell-bg: #ffffff;
            --bell-icon: #777;
            --bell-gradient-start: #0070f3;
            --bell-gradient-end: #5ce1e6;
            --avatar-bg: #f0f2f5;
        }
        body.dark-mode {
            --bg: #1a1a2e;
            --card-bg: #16213e;
            --text: #e0e0e0;
            --border: #2a2a4a;
            --primary: #3b82f6;
            --primary-hover: #2563eb;
            --secondary: #4b5563;
            --secondary-hover: #374151;
            --shadow: rgba(0,0,0,0.3);
            --noti-bg: #1e293b;
            --search-bg: #1e293b;
            --search-glow: rgba(59,130,246,0.2);
            --bell-bg: #1e293b;
            --bell-icon: #cbd5e1;
            --bell-gradient-start: #3b82f6;
            --bell-gradient-end: #00bf63;
            --avatar-bg: #2a2a4a;
        }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif;
            font-weight: 500;
            max-width: 900px; margin: 0 auto; padding: 16px; background: var(--bg);
            line-height: 1.6; color: var(--text);
            transition: background 0.3s, color 0.3s;
        }
        h1, h2, h3 { font-weight: 700; }
        h1 { border-bottom: 2px solid var(--border); font-size: 1.8em; }
        .hidden { display: none !important; }
        .auth-container {
            max-width: 400px; margin: 30px auto; background: var(--card-bg); padding: 24px;
            border-radius: 12px; box-shadow: 0 4px 12px var(--shadow);
        }
        .auth-tabs { display: flex; margin-bottom: 20px; }
        .auth-tab { flex: 1; text-align: center; padding: 12px; cursor: pointer; border-bottom: 2px solid transparent; font-weight: 600; color: var(--text); }
        .auth-tab.active { border-bottom-color: var(--primary); color: var(--primary); }
        .form-group { margin-bottom: 18px; }
        .form-group label { display: block; margin-bottom: 6px; color: var(--text); font-weight: 600; }
        .form-group input {
            width: 100%; padding: 12px; border: 1px solid var(--border); border-radius: 8px;
            font-size: 16px; font-family: inherit; background: var(--card-bg); color: var(--text);
        }
        button {
            padding: 12px 20px; background: var(--primary); color: white; border: none;
            border-radius: 8px; cursor: pointer; font-size: 16px; font-family: inherit;
            font-weight: 600; transition: background 0.2s; outline: none;
        }
        button:hover { background: var(--primary-hover); }
        .error-message { color: #e74c3c; margin-top: 12px; }
        
        .navbar {
            display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center;
            margin-bottom: 20px; padding-bottom: 12px; border-bottom: 1px solid var(--border);
        }
        .navbar h1 { border: none; margin: 0; font-size: 1.6em; }
        .user-info { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
        .avatar, .noti-avatar, .profile-avatar, .avatar-placeholder { 
            width: 36px; height: 36px; border-radius: 50%; object-fit: cover;
            flex-shrink: 0; border: 1px solid var(--border);
        }
        .avatar, .noti-avatar, .profile-avatar { background: var(--avatar-bg); }
        .avatar-placeholder {
            background: var(--primary); color: white; display: flex; 
            align-items: center; justify-content: center; font-weight: 700; font-size: 1.2em;
        }
        .nav-links { display: flex; gap: 12px; align-items: center; }
        .nav-links button { padding: 8px 16px; font-size: 14px; background: var(--secondary); }
        .nav-links button:hover { background: var(--secondary-hover); }

        .notification-wrapper { position: relative; display: inline-block; }
        .noti-bell {
            position: relative; width: 40px; height: 40px; background: var(--bell-bg);
            border-radius: 40px; cursor: pointer; display: flex; justify-content: center; align-items: center;
            box-shadow: 0 4px 8px rgba(0,0,0,0.05); transition: all 0.4s ease; border: none; padding: 0; outline: none; overflow: hidden;
        }
        .noti-bell:hover { opacity: 0.8; }
        .bell-icon { font-size: 1.5em; color: var(--bell-icon); }
        
        .noti-badge { position: absolute; top: 2px; right: 2px; background: #e74c3c; color: white; border-radius: 50%; width: 16px; height: 16px; font-size: 10px; display: flex; align-items: center; justify-content: center; z-index: 5; pointer-events: none; transition: all 0.3s; }
        .noti-bell:hover .noti-badge { right: 8px; top: 50%; transform: translateY(-50%); }
        .noti-dropdown { position: absolute; right: 0; top: 48px; width: 320px; max-width: 90vw; background: var(--noti-bg); border: 1px solid var(--border); border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.2); z-index: 999; display: none; max-height: 400px; overflow-y: auto; }
        .noti-header { padding: 12px 15px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; font-weight: 600; }
        .noti-item { padding: 12px 15px; border-bottom: 1px solid var(--border); display: flex; align-items: flex-start; gap: 10px; cursor: pointer; }
        .noti-item.unread { background: var(--comment-highlight); }
        .noti-item img { width: 32px; height: 32px; border-radius: 50%; object-fit: cover; }
        .noti-content { flex: 1; font-size: 0.9em; }
        .noti-time { font-size: 0.8em; opacity: 0.7; margin-top: 4px; }
        .noti-empty { padding: 20px; text-align: center; opacity: 0.7; }


        .switch {
            position: fixed; bottom: 20px; right: 20px; z-index: 1000;
            font-size: 17px;
            display: inline-block;
            width: 3.5em;
            height: 2em;
            transform-style: preserve-3d;
            perspective: 500px;
            animation: toggle__animation 3s infinite;
        }
        .switch::before {
            content: "";
            position: absolute;
            width: 100%;
            height: 100%;
            left: 0;
            top: 0;
            filter: blur(20px);
            z-index: -1;
            border-radius: 50px;
            background-color: #d8ff99;
            background-image: radial-gradient(at 21% 46%, hsla(183,65%,60%,1) 0px, transparent 50%),
            radial-gradient(at 23% 25%, hsla(359,74%,70%,1) 0px, transparent 50%),
            radial-gradient(at 20% 1%, hsla(267,83%,75%,1) 0px, transparent 50%),
            radial-gradient(at 86% 87%, hsla(204,69%,68%,1) 0px, transparent 50%),
            radial-gradient(at 99% 41%, hsla(171,72%,77%,1) 0px, transparent 50%),
            radial-gradient(at 55% 24%, hsla(138,60%,62%,1) 0px, transparent 50%);
        }
        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }
        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #fdfefedc;
            transition: .4s;
            border-radius: 30px;
        }
        .slider:before {
            position: absolute;
            content: "";
            height: 1.4em;
            width: 1.4em;
            left: 0.3em;
            bottom: 0.35em;
            transition: .4s;
            border-radius: 50%;
            box-shadow: rgba(0, 0, 0, 0.17) 0px -10px 10px 0px inset,
                 rgba(0, 0, 0, 0.09) 0px -1px 15px -8px;
            background-color: #ff99fd;
            background-image: radial-gradient(at 81% 39%, hsla(327,79%,79%,1) 0px, transparent 50%),
            radial-gradient(at 11% 72%, hsla(264,64%,79%,1) 0px, transparent 50%),
            radial-gradient(at 23% 20%, hsla(75,98%,71%,1) 0px, transparent 50%);
        }
        .input__check:checked + .slider {
            background-color: #17202A;
        }
        .input__check:checked + .slider:before {
            transform: translateX(1.5em);
        }
        @keyframes toggle__animation {
            0%, 100% { transform: translateY(-10px) rotateX(15deg) rotateY(-20deg); }
            50% { transform: translateY(0px) rotateX(15deg) rotateY(-20deg); }
        }

        .shadow__btn {
            padding: 10px 20px; border: none; font-size: 17px; color: #fff; border-radius: 7px;
            letter-spacing: 4px; font-weight: 700; text-transform: uppercase; transition: 0.5s;
            transition-property: box-shadow, transform; background: rgb(0,140,255);
            box-shadow: 0 0 25px rgb(0,140,255); cursor: pointer; display: inline-flex;
            align-items: center; justify-content: center; outline: none;
        }
        .shadow__btn svg {
            width: 1.2em; height: 1.2em; margin-right: 0.5em; stroke-width: 2px;
        }
        .shadow__btn:hover {
            box-shadow: 0 0 5px rgb(0,140,255), 0 0 25px rgb(0,140,255),
                        0 0 50px rgb(0,140,255), 0 0 100px rgb(0,140,255);
            transform: translateY(-2px);
        }
        .shadow__btn:active { transform: scale(0.95); }
        body.dark-mode .shadow__btn {
            background: rgb(30, 136, 229);
            box-shadow: 0 0 25px rgba(30, 136, 229, 0.6);
        }
        body.dark-mode .shadow__btn:hover {
            box-shadow: 0 0 5px rgba(30, 136, 229, 0.8), 0 0 25px rgba(30, 136, 229, 0.8),
                        0 0 50px rgba(30, 136, 229, 0.6), 0 0 100px rgba(30, 136, 229, 0.4);
        }

        #docList { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 20px; }
        .doc-btn { background: var(--primary); color: white; border: none; border-radius: 30px; padding: 8px 20px; font-size: 16px; cursor: pointer; font-weight: 600; }
        .doc-btn:hover { background: var(--primary-hover); }
        
        .profile-header { display: flex; flex-direction: column; align-items: center; gap: 20px; margin: 20px 0; }
        @media (min-width: 600px) { .profile-header { flex-direction: row; align-items: flex-start; } }
        .profile-avatar { width: 100px; height: 100px; border-radius: 50%; object-fit: cover; }
        .my-articles { margin-top: 24px; }
        .article-item { margin: 8px 0; display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
        .article-btn { background: var(--primary); color: white; border: none; border-radius: 30px; padding: 8px 18px; font-size: 14px; cursor: pointer; font-weight: 600; }
        .article-btn:hover { background: var(--primary-hover); }

        #loadingOverlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: var(--bg); display: flex; justify-content: center; align-items: center;
            z-index: 9999;
        }

        @media (max-width: 600px) {
            .switch { width: 3em; height: 1.7em; bottom: 16px; right: 16px; }
            .navbar { flex-direction: column; align-items: flex-start; }
        }
        ::selection { background: var(--primary); color: white; }
        /* 极简搜索框 */
        .input {
            border: none;
            outline: none;
            border-radius: 15px;
            padding: 1em;
            background-color: #ccc;
            box-shadow: inset 2px 5px 10px rgba(0,0,0,0.3);
            transition: 300ms ease-in-out;
            width: 200px;
            margin-bottom: 15px;
            font-size: 15px;
            display: block;
        }
        .input:focus {
            background-color: white;
            transform: scale(1.05);
            box-shadow: 13px 13px 100px #969696,
                        -13px -13px 100px #ffffff;
            width: 250px;
        }
        body.dark-mode .input {
            background-color: #2a2a4a;
            color: #eee;
            box-shadow: inset 2px 5px 10px rgba(0,0,0,0.6);
        }
        body.dark-mode .input:focus {
            background-color: #1e1e2e;
            box-shadow: 13px 13px 100px #000,
                        -13px -13px 100px #3a3a5a;
        }
        /* === 立体按钮样式（恢复） === */
        .basic-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            outline: none;
            cursor: pointer;
            width: auto;
            min-width: 80px;
            height: 36px;
            padding: 0 18px;
            background-image: linear-gradient(to top, #D8D9DB 0%, #fff 80%, #FDFDFD 100%);
            border-radius: 30px;
            border: 1px solid #8F9092;
            transition: all 0.2s ease;
            font-family: inherit;
            font-size: 14px;
            font-weight: 600;
            color: #606060;
            text-shadow: 0 1px #fff;
            white-space: nowrap;
        }
        .basic-btn:hover {
            box-shadow: 0 4px 3px 1px #FCFCFC, 0 6px 8px #D6D7D9, 0 -4px 4px #CECFD1, 0 -6px 4px #FEFEFE, inset 0 0 3px 3px #CECFD1;
        }
        .basic-btn:active,
        .basic-btn:focus {
            box-shadow: 0 4px 3px 1px #FCFCFC, 0 6px 8px #D6D7D9, 0 -4px 4px #CECFD1, 0 -6px 4px #FEFEFE, inset 0 0 5px 3px #999, inset 0 0 30px #aaa;
        }
        .nav-links button, .nav-links button:hover, .nav-links button:focus,
        .back-btn, .back-btn:hover, .back-btn:focus {
            background-image: linear-gradient(to top, #D8D9DB 0%, #fff 80%, #FDFDFD 100%) !important;
            background-color: transparent !important;
            color: #606060 !important;
            border: 1px solid #8F9092 !important;
            box-shadow: none !important;
            text-shadow: 0 1px #fff !important;
            font-weight: 600 !important;
            transition: all 0.2s ease !important;
            font-family: inherit !important;
            font-size: 14px !important;
            height: 36px !important;
            padding: 0 18px !important;
            border-radius: 30px !important;
            display: inline-flex !important;
            align-items: center !important;
            justify-content: center !important;
            white-space: nowrap !important;
        }
        .nav-links button:hover, .back-btn:hover {
            box-shadow: 0 4px 3px 1px #FCFCFC, 0 6px 8px #D6D7D9, 0 -4px 4px #CECFD1, 0 -6px 4px #FEFEFE, inset 0 0 3px 3px #CECFD1 !important;
        }
        .nav-links button:active, .back-btn:active,
        .nav-links button:focus, .back-btn:focus {
            box-shadow: 0 4px 3px 1px #FCFCFC, 0 6px 8px #D6D7D9, 0 -4px 4px #CECFD1, 0 -6px 4px #FEFEFE, inset 0 0 5px 3px #999, inset 0 0 30px #aaa !important;
        }
        body.dark-mode .nav-links button,
        body.dark-mode .back-btn,
        body.dark-mode .nav-links button:hover,
        body.dark-mode .back-btn:hover,
        body.dark-mode .nav-links button:focus,
        body.dark-mode .back-btn:focus {
            background-image: linear-gradient(to top, #D8D9DB 0%, #fff 80%, #FDFDFD 100%) !important;
            color: #606060 !important;
            text-shadow: 0 1px #fff !important;
        }
    </style>
</head>
<body>
    <div id="loadingOverlay"><div style="font-size: 1.5em; color: var(--text);">加载中...</div></div>

    <div id="authView" class="hidden">
        <div class="auth-container">
            <div class="auth-tabs"><div class="auth-tab active" data-tab="login">登录</div><div class="auth-tab" data-tab="register">注册</div></div>
            <div id="loginForm">
                <div class="form-group"><label>用户名</label><input type="text" id="loginUsername"></div>
                <div class="form-group"><label>密码</label><input type="password" id="loginPassword"></div>
                <button onclick="handleLogin()">登录</button>
            </div>
            <div id="registerForm" class="hidden">
                <div class="form-group"><label>用户名</label><input type="text" id="regUsername" placeholder="英文或数字用户名（勿用中文）"></div>
                <div class="form-group"><label>笔名</label><input type="text" id="regNickname"></div>
                <div class="form-group"><label>密码</label><input type="password" id="regPassword"></div>
                <button onclick="handleRegister()">注册</button>
            </div>
            <div id="authError" class="error-message"></div>
        </div>
    </div>

    <div id="mainView" class="hidden">
        <div class="navbar">
            <h1>📢 大厅</h1>
            <div class="user-info">
                <span id="displayNickname"></span>
                <div id="avatarContainer"></div>
                <div class="nav-links">
                    <button onclick="showProfile()">个人主页</button>
                    <button onclick="logout()" style="background:var(--secondary);">退出</button>
                    <span style="margin-left: 10px; font-weight: 500;">🟢 <span id="onlineCount">0</span> 在线</span>
                    <div class="notification-wrapper">
                        <button class="noti-bell" onclick="toggleNotiDropdown()">
                            <span class="bell-icon">🔔</span>
                            
                            <span id="notiBadge" class="noti-badge" style="display:none;">0</span>
                        </button>
                        <div id="notiDropdown" class="noti-dropdown">
                            <div class="noti-header"><span>通知</span><a href="#" onclick="markAllRead(); return false;" style="color:var(--primary);">全部已读</a></div>
                            <div id="notiList">加载中...</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <input id="searchInput" class="input" type="text" placeholder="搜索文章/用户..." required>
        <button class="shadow__btn" onclick="createNewDoc()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            创建新文章
        </button>
        <h2>📚 所有文章</h2>
        <div id="docList">加载中...</div>
    </div>

    <div id="profileView" class="hidden">
        <div class="navbar">
            <h1>👤 个人主页</h1>
            <div class="nav-links">
                <button onclick="showMain()">← 返回大厅</button>
            </div>
        </div>
        <div id="profileContent"></div>
    </div>

    <label class="switch">
        <input type="checkbox" class="input__check" id="themeCheckbox">
        <span class="slider"></span>
    </label>

    <script src="https://cdn.socket.io/4.5.0/socket.io.min.js"></script>
    <script>
        const themeCheckbox = document.getElementById('themeCheckbox');
        function initTheme() {
            const isDark = localStorage.getItem('theme') === 'dark';
            document.body.classList.toggle('dark-mode', isDark);
            themeCheckbox.checked = isDark;
        }
        themeCheckbox.addEventListener('change', function(e) {
            document.body.classList.toggle('dark-mode', this.checked);
            localStorage.setItem('theme', this.checked ? 'dark' : 'light');
        });
        initTheme();

        let currentUser = null;
        const socket = io();
        
        socket.on('online_count', (data) => document.getElementById('onlineCount').innerText = data.count);

        socket.on('new_notification', (data) => {
            if (!currentUser) return;
            const { notification, unread_count } = data;
            updateNotiBadge(unread_count);
            if (!notification.read) {
                if (Notification.permission === 'granted') {
                    new Notification(notification.type === 'reply' ? '有人回复了你' : '有人点赞了你的评论', {
                        body: notification.content,
                        icon: '/static/favicon.ico'
                    });
                }
                showToast(notification.type === 'reply' ? '有人回复了你' : '有人点赞了你的评论', notification.content);
            }
        });

        function checkLogin() {
            const stored = localStorage.getItem('currentUser');
            if (stored) {
                try {
                    currentUser = JSON.parse(stored);
                    authFetch('/api/current_user', { headers: { 'X-Username': currentUser.username } })
                        .then(res => res.json())
                        .then(data => {
                            document.getElementById('loadingOverlay').style.display = 'none';
                            if (data.user) {
                                currentUser = data.user;
                                localStorage.setItem('token', data.token);
localStorage.setItem('currentUser', JSON.stringify(currentUser));
                                showMain();
                                updateMsgBadge();
                                socket.emit('join', { username: currentUser.username });
                                if (Notification.permission === 'default') Notification.requestPermission();
                            } else {
                                showMain();
                                updateMsgBadge();
                                socket.emit('join', { username: currentUser.username });
                            }
                        }).catch(() => {
                            document.getElementById('loadingOverlay').style.display = 'none';
                            showMain();
                            updateMsgBadge();
                            socket.emit('join', { username: currentUser.username });
                        });
                } catch(e) {
                    document.getElementById('loadingOverlay').style.display = 'none';
                    showAuth();
                }
            } else {
                document.getElementById('loadingOverlay').style.display = 'none';
                showAuth();
            }
        }

        function showAuth() {
            document.getElementById('authView').classList.remove('hidden');
            document.getElementById('mainView').classList.add('hidden');
            document.getElementById('profileView').classList.add('hidden');
        }
        function showMain() {
            document.getElementById('authView').classList.add('hidden');
            document.getElementById('mainView').classList.remove('hidden');
            document.getElementById('profileView').classList.add('hidden');
            updateNavbar();
            loadDocList();
        }
        function showProfile() {
            document.getElementById('authView').classList.add('hidden');
            document.getElementById('mainView').classList.add('hidden');
            document.getElementById('profileView').classList.remove('hidden');
            loadProfile();
        }
        function logout() {
            currentUser = null;
            localStorage.removeItem('currentUser');
            showAuth();
        }

        function updateNavbar() {
            if (currentUser) {
                document.getElementById('displayNickname').innerText = currentUser.nickname;
                const avatarCont = document.getElementById('avatarContainer');
                if (currentUser.avatar) {
                    avatarCont.innerHTML = `<img src="/avatars/${currentUser.avatar}" class="avatar">`;
                } else {
                    avatarCont.innerHTML = `<div class="avatar-placeholder">${currentUser.nickname.charAt(0).toUpperCase()}</div>`;
                }
            }
        }

        document.querySelectorAll('.auth-tab').forEach(tab => {
            tab.addEventListener('click', function() {
                document.querySelectorAll('.auth-tab').forEach(t => t.classList.remove('active'));
                this.classList.add('active');
                const isLogin = this.dataset.tab === 'login';
                document.getElementById('loginForm').classList.toggle('hidden', !isLogin);
                document.getElementById('registerForm').classList.toggle('hidden', isLogin);
            });
        });

        async function handleLogin() {
            const username = document.getElementById('loginUsername').value.trim();
            const password = document.getElementById('loginPassword').value;
            if (!username || !password) return alert('请输入用户名和密码');
            const res = await authFetch('/api/login', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, password }) });
            const data = await res.json();
            if (data.status === 'ok') {
                currentUser = data.user;
                localStorage.setItem('token', data.token);
localStorage.setItem('currentUser', JSON.stringify(currentUser));
                showMain();
                updateMsgBadge();
                socket.emit('join', { username: currentUser.username });
                if (Notification.permission === 'default') Notification.requestPermission();
            } else document.getElementById('authError').innerText = data.message;
        }

        async function handleRegister() {
            const username = document.getElementById('regUsername').value.trim();
            const nickname = document.getElementById('regNickname').value.trim();
            const password = document.getElementById('regPassword').value;
            if (!username || !nickname || !password) return alert('请完整填写');
            const res = await authFetch('/api/register', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, nickname, password }) });
            const data = await res.json();
            if (data.status === 'ok') {
                alert('注册成功，请登录');
                document.querySelector('[data-tab="login"]').click();
            } else document.getElementById('authError').innerText = data.message;
        }

        async function loadDocList() {
            const res = await authFetch('/api/docs');
            const docs = await res.json();
            let html = '';
            docs.forEach(item => {
                const title = item.title || item.id;
                html += `<button class="doc-btn" onclick="location.href='/read/${item.id}'">📖 #${item.number} ${title}</button>`;
            });
            document.getElementById('docList').innerHTML = html || '<p>暂无文章</p>';
        }

        function createNewDoc() {
            const docId = prompt('输入新文章标题:');
            if (docId) {
                authFetch('/api/create_doc', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Username': currentUser.username }, body: JSON.stringify({ docId }) })
                    .then(() => { window.location.href = `/edit/${docId}`; });
            }
        }

        async function loadProfile() {
            if (!currentUser) return;
            const res = await authFetch(`/api/user/${encodeURIComponent(currentUser.username)}`, { headers: { 'X-Username': currentUser.username } });
            const userData = await res.json();
            if (!userData || !userData.nickname) return;
            const articles = userData.articles || [];
            document.getElementById('profileContent').innerHTML = `
                <div class="profile-header">
                    ${currentUser.avatar ? `<img src="/avatars/${currentUser.avatar}" class="profile-avatar">` : `<div class="avatar-placeholder" style="width:100px;height:100px;font-size:40px;">${currentUser.nickname.charAt(0)}</div>`}
                    <div style="flex:1;">
                        <h2>${currentUser.nickname} (@${currentUser.username})</h2>
                        <p>参与创作 ${articles.length} 篇文章  |  <a href="#" onclick="showMyFollowers()">粉丝 ${userData.followers_count||0}</a>  |  <a href="#" onclick="showMyFollowing()">关注 ${userData.following_count||0}</a></p>
                        <button class="basic-btn" onclick="document.getElementById('avatarUpload').click()">更换头像</button>
                        <input type="file" id="avatarUpload" accept="image/*" style="display:none;" onchange="uploadAvatar(this)">
                    </div>
                </div>
                <div class="my-articles"><h3>我的文章</h3>${articles.map(a => `<div class="article-item"><button class="article-btn" onclick="location.href='/read/${a.id}'">#${a.number} ${a.title||a.id}</button></div>`).join('')}</div>
            `;
        }

        async function updateNotiBadge(customCount) {
            if (!currentUser) return;
            const cnt = customCount !== undefined ? customCount : (await authFetch('/api/notifications/count', { headers: { 'X-Username': currentUser.username } }).then(r=>r.json())).count;
            const badge = document.getElementById('notiBadge');
            badge.textContent = cnt || 0;
            badge.style.display = cnt > 0 ? 'flex' : 'none';
        }

        async function loadNotifications() {
            if (!currentUser) return;
            const res = await authFetch('/api/notifications', { headers: { 'X-Username': currentUser.username } });
            const notis = await res.json();
            document.getElementById('notiList').innerHTML = notis.length ? notis.map(n => `
                <div class="noti-item ${n.read?'':'unread'}" onclick="markReadAndGo('${n.id}','${n.doc_id}','${n.comment_id||''}')">
                    ${n.from_avatar ? `<img src="/avatars/${n.from_avatar}" class="noti-avatar">` : `<div class="noti-avatar">${n.from_user?.charAt(0)||'?'}</div>`}
                    <div class="noti-content"><strong>${n.from_user}</strong> ${n.type==='reply'?'回复了你':'赞了你的评论'}<div>${n.content||''}</div><div class="noti-time">${new Date(n.timestamp).toLocaleString()}</div></div>
                </div>`).join('') : '<div class="noti-empty">暂无通知</div>';
        }

        window.toggleNotiDropdown = () => {
            const dd = document.getElementById('notiDropdown');
            if (dd.style.display === 'block') dd.style.display = 'none';
            else { loadNotifications(); dd.style.display = 'block'; }
        };

        window.markAllRead = async () => {
            if (!currentUser) return;
            await authFetch('/api/notifications/read', { method: 'POST', headers: { 'X-Username': currentUser.username } });
            updateNotiBadge(0);
            loadNotifications();
        };

        window.markReadAndGo = async (notiId, docId, commentId) => {
            if (currentUser && notiId) {
                let readList = JSON.parse(localStorage.getItem('readNotis')||'[]');
                if (!readList.includes(notiId)) { readList.push(notiId); localStorage.setItem('readNotis', JSON.stringify(readList)); }
                updateMsgBadge();
            }
            if (docId) window.location.href = commentId ? `/read/${docId}#comment-${commentId}` : `/read/${docId}`;
        };

        function showToast(title, content) {
            const toast = document.createElement('div');
            toast.style.cssText = 'position:fixed;top:20px;right:20px;background:var(--card-bg);border:1px solid var(--border);border-radius:8px;padding:12px 16px;box-shadow:var(--shadow);z-index:9999;animation:toastSlideIn .3s ease';
            toast.innerHTML = `<strong style="color:var(--primary)">${title}</strong><div>${content}</div>`;
            document.body.appendChild(toast);
            setTimeout(() => { toast.style.animation='toastSlideOut .3s ease'; setTimeout(()=>toast.remove(),300); }, 3000);
        }

        checkLogin();
    </script>
</body>
</html>
