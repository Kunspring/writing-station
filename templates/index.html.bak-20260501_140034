    <div id="authView" class="hidden">
        <div class="auth-container">
            <div class="auth-tabs"><div class="auth-tab active" data-tab="login">登录</div><div class="auth-tab" data-tab="register">注册</div></div>
            <div id="loginForm">
                <div class="form-group"><label>用户名</label><input type="text" id="loginUsername"></div>
                <div class="form-group"><label>密码</label><input type="password" id="loginPassword"></div>
                <button onclick="handleLogin()">登录</button>
            </div>
            <div id="registerForm" class="hidden">
                <div class="form-group"><label>用户名</label><input type="text" id="regUsername" placeholder="英文或数字用户名（勿用中文）"></div>
                <div class="form-group"><label>笔名</label><input type="text" id="regNickname"></div>
                <div class="form-group"><label>密码</label><input type="password" id="regPassword"></div>
                <button onclick="handleRegister()">注册</button>
            </div>
            <div id="authError" class="error-message"></div>
        </div>
    </div>

    <div id="mainView" class="hidden">
        <div class="navbar">
            <h1>大厅</h1>
            <div class="user-info">
                <span id="displayNickname"></span>
                <div id="avatarContainer"></div>
                <div class="nav-links">
                    <button onclick="location.href='/collections'" style="background:var(--primary);color:white;">📚 合集</button>
                    <button onclick="location.href='/messages'">✉️ 消息</button>
                    <button onclick="showProfile()">个人主页</button>
                    <button onclick="logout()" style="background:var(--secondary);">退出</button>
                    <div class="notification-wrapper">
                        <button class="noti-bell" onclick="toggleNotiDropdown()">
                            <span class="bell-icon">🔔</span>
                            
                            <span id="notiBadge" class="noti-badge" style="display:none;">0</span>
                        </button>
                        <div id="notiDropdown" class="noti-dropdown">
                            <div class="noti-header"><span>通知</span><a href="#" onclick="markAllRead(); return false;" style="color:var(--primary);">全部已读</a></div>
                            <div id="notiList">加载中...</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <form onsubmit="clearTimeout(searchTimer);doSearch();return false" style="display:contents">
        <input id="searchInput" class="input" type="text" placeholder="搜索文章 (@用户名搜用户)..." oninput="search()">
        </form>
        <button class="basic-btn" onclick="createNewDoc()">+ 创建新文章</button>
        <h2>所有文章</h2>
        <div id="docList">加载中...</div>
        <div id="draftsSection" style="display:none;margin-top:24px;">
            <h2>我的草稿</h2>
            <div id="draftList">加载中...</div>
        </div>
    </div>

    <div id="profileView" class="hidden">
        <div class="navbar">
            <h1>个人主页</h1>
            <div class="nav-links">
                <button onclick="showMain()">← 返回大厅</button>
            </div>
        </div>
        <div id="profileContent"></div>
    </div>

    <label class="switch">
        <input type="checkbox" class="input__check" id="themeCheckbox">
        <span class="slider"></span>
    </label>

    <script>
        const themeCheckbox = document.getElementById('themeCheckbox');
        function initTheme() {
            const isDark = localStorage.getItem('theme') === 'dark';
            document.body.classList.toggle('dark-mode', isDark);
            themeCheckbox.checked = isDark;
        }
        themeCheckbox.addEventListener('change', function(e) {
            document.body.classList.toggle('dark-mode', this.checked);
            localStorage.setItem('theme', this.checked ? 'dark' : 'light');
        });
        initTheme();

        let currentUser = null;

        window.onload = async function() {
            currentUser = await checkLogin();
            if (!currentUser) return;
            initEditor();
            await load();

            // ✅ 隐藏遮罩，淡入内容
            const overlay = document.getElementById('loadingOverlay');
            const elementsToFadeIn = document.querySelectorAll('body > .toolbar, body > .status-bar, .EasyMDEContainer');
            const MIN_LOADING_TIME = 700;
            const startTime = performance.now();
            const elapsed = performance.now() - startTime;
    const remaining = Math.max(0, MIN_LOADING_TIME - elapsed);
            // 遮罩淡出
            setTimeout(() => {
            overlay.style.opacity = '0';
            // 内容淡入（已在CSS设 opacity:0, transition: 0.6s）
            elementsToFadeIn.forEach(el => el.style.opacity = '1');
            
            // 动画结束后移除遮罩DOM，防止遮挡点击
            setTimeout(() => {
                if (overlay && overlay.parentNode) {
                    overlay.parentNode.removeChild(overlay);
                }
            }, 400); // 与过渡时间匹配
                }, remaining);
        }
        function authFetch(url, options = {}) {
            const token = localStorage.getItem('token');
            if (token) {
                options.headers = {
                    ...options.headers,
                    'Authorization': 'Bearer ' + token
                };
            }
            return fetch(url, { ...options, signal: AbortSignal.timeout(15000) });
        }

        let hideRequested = false;
        const PAGE_LOAD_TIME = Date.now();

        function checkLogin() {
            const stored = localStorage.getItem('currentUser');
            if (stored) {
                try {
                    currentUser = JSON.parse(stored);
                    hideLoadingOverlay();
                    authFetch('/api/current_user')
                        .then(res => {
                            if (res.status === 401) {
                                localStorage.removeItem('token');
                                localStorage.removeItem('currentUser');
                                currentUser = null;
                                showAuth();
                                return null;
                            }
                            return res.json();
                        })
                        .then(data => {
                            if (!data) return;
                            if (data.user) {
                                currentUser = data.user;
                                localStorage.setItem('currentUser', JSON.stringify(currentUser));
                                try {
                                    showMain();
                                    updateMsgBadge();
                                    if (Notification.permission === 'default') Notification.requestPermission();
                                } catch(e) {
                                    // 界面错误不触发掉登录
                                    console.error('UI init error:', e);
                                }
                            } else {
                                localStorage.removeItem('token');
                                localStorage.removeItem('currentUser');
                                currentUser = null;
                                showAuth();
                            }
                        }).catch((e) => {
                            // 仅网络/服务器异常才走掉登录
                            console.error('Auth check failed:', e);
                            localStorage.removeItem('token');
                            localStorage.removeItem('currentUser');
                            currentUser = null;
                            showAuth();
                        });
                } catch(e) {
                    showAuth();
                }
            } else {
                hideLoadingOverlay();
                showAuth();
            }
        }

        function showAuth() {
            document.getElementById('authView').classList.remove('hidden');
            document.getElementById('mainView').classList.add('hidden');
            document.getElementById('profileView').classList.add('hidden');
        }
        function showMain() {
            document.getElementById('authView').classList.add('hidden');
            document.getElementById('mainView').classList.remove('hidden');
            document.getElementById('profileView').classList.add('hidden');
            updateNavbar();
            loadDocList();
        }
        function showProfile() {
            document.getElementById('authView').classList.add('hidden');
            document.getElementById('mainView').classList.add('hidden');
            document.getElementById('profileView').classList.remove('hidden');
            loadProfile();
        }
        function logout() {
            currentUser = null;
            localStorage.removeItem('token');
            localStorage.removeItem('currentUser');
            showAuth();
        }

        function updateNavbar() {
            if (currentUser) {
                document.getElementById('displayNickname').innerText = currentUser.nickname;
                const avatarCont = document.getElementById('avatarContainer');
                if (currentUser.avatar) {
                    avatarCont.innerHTML = `<img src="/avatars/${currentUser.avatar}" class="avatar">`;
                } else {
                    avatarCont.innerHTML = `<div class="avatar-placeholder">${currentUser.nickname.charAt(0).toUpperCase()}</div>`;
                }
            }
        }

        document.querySelectorAll('.auth-tab').forEach(tab => {
            tab.addEventListener('click', function() {
                document.querySelectorAll('.auth-tab').forEach(t => t.classList.remove('active'));
                this.classList.add('active');
                const isLogin = this.dataset.tab === 'login';
                document.getElementById('loginForm').classList.toggle('hidden', !isLogin);
                document.getElementById('registerForm').classList.toggle('hidden', isLogin);
            });
        });

        async function handleLogin() {
            const username = document.getElementById('loginUsername').value.trim();
            const password = document.getElementById('loginPassword').value;
            if (!username || !password) return alert('请输入用户名和密码');
            const res = await authFetch('/api/login', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, password }) });
            const data = await res.json();
            if (data.status === 'ok') {
                currentUser = data.user;
                localStorage.setItem('token', data.token);
localStorage.setItem('currentUser', JSON.stringify(currentUser));
                showMain();
                updateMsgBadge();
                if (Notification.permission === 'default') Notification.requestPermission();
            } else document.getElementById('authError').innerText = data.message;
        }

        async function handleRegister() {
            const username = document.getElementById('regUsername').value.trim();
            const nickname = document.getElementById('regNickname').value.trim();
            const password = document.getElementById('regPassword').value;
            if (!username || !nickname || !password) return alert('请完整填写');
            const res = await authFetch('/api/register', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username, nickname, password }) });
            const data = await res.json();
            if (data.status === 'ok') {
                alert('注册成功，请登录');
                document.querySelector('[data-tab="login"]').click();
            } else document.getElementById('authError').innerText = data.message;
        }

        async function loadDocList() {
            const res = await authFetch('/api/docs');
            const docs = await res.json();
            let html = '';
            docs.forEach(item => {
                const title = item.title || item.id;
                const author = (item.authors || [])[0] || '';
                const cover = item.cover || '';
                const coverHtml = cover 
                    ? `<img class="doc-card-img" src="${cover}" alt="${title}" loading="lazy">`
                    : `<div class="doc-card-placeholder"><span>${title}</span></div>`;
                html += `<div class="doc-card" onclick="location.href='/read/${item.id}'">
                    ${coverHtml}
                    <div class="doc-card-info">
                        <div class="doc-card-title">${title}</div>
                        <div class="doc-card-meta"><span>${author}</span><span>#${item.number}</span></div>
                    </div>
                </div>`;
            });
            document.getElementById('docList').innerHTML = html || '<p>暂无文章</p>';
        }

        async function toggleDrafts() {
            console.log('toggleDrafts called, currentUser:', currentUser);
            if (!currentUser) { alert('请先登录'); return; }
            const section = document.getElementById('draftsSection');
            const list = document.getElementById('draftList');
            console.log('section:', section, 'list:', list);
            if (!section || !list) return;
            // 切换显示/隐藏
            if (section.style.display === 'block') {
                section.style.display = 'none';
                return;
            }
            section.style.display = 'block';
            list.innerHTML = '<p>加载中...</p>';
            try {
                const res = await authFetch('/api/my_drafts');
                const drafts = await res.json();
                console.log('drafts:', drafts);
                if (!Array.isArray(drafts) || drafts.length === 0) {
                    list.innerHTML = '<p>暂无草稿</p>';
                } else {
                    list.innerHTML = drafts.map(d => 
                        `<button class="doc-btn" onclick="location.href='/edit/${d.id}'" style="opacity:0.85;">📝 #${d.number} ${d.title}</button>`
                    ).join('');
                }
            } catch(e) {
                list.innerHTML = '<p style="color:red;">加载失败，请刷新重试</p>';
                console.error('drafts load error:', e);
            }
        }
        window.toggleDrafts = toggleDrafts;

        function createNewDoc() {
            const docId = prompt('输入新文章标题:');
            if (docId) {
                authFetch('/api/create_doc', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ docId }) })
                    .then(r => r.json())
                    .then(data => { window.location.href = `/edit/${data.doc_id}`; })
                    .catch(() => alert('创建失败，请刷新重试'));
            }
        }

        async function loadProfile() {
            if (!currentUser) return;
            const res = await authFetch(`/api/user/${encodeURIComponent(currentUser.username)}`, { headers: { 'X-Username': currentUser.username } });
            const userData = await res.json();
            if (!userData || !userData.nickname) return;
            const articles = userData.articles || [];
            document.getElementById('profileContent').innerHTML = `
                <div class="profile-header">
                    ${currentUser.avatar ? `<img src="/avatars/${currentUser.avatar}" class="profile-avatar">` : `<div class="avatar-placeholder" style="width:100px;height:100px;font-size:40px;">${currentUser.nickname.charAt(0)}</div>`}
                    <div style="flex:1;">
                        <h2>${currentUser.nickname} (@${currentUser.username})</h2>
                        <p>参与创作 ${articles.length} 篇文章  |  <a href="#" onclick="showMyFollowers()">粉丝 ${userData.followers_count||0}</a>  |  <a href="#" onclick="showMyFollowing()">关注 ${userData.following_count||0}</a></p>
                        <button class="basic-btn" onclick="document.getElementById('avatarUpload').click()">更换头像</button>
                        <input type="file" id="avatarUpload" accept="image/*" style="display:none;" onchange="uploadAvatar(this)">
                    </div>
                </div>
                <div class="my-articles"><h3>我的文章</h3><div id="profileDocList">${articles.map(a => {
                    const cover = a.cover || '';
                    const coverHtml = cover
                        ? `<img class="doc-card-img" src="${cover}" alt="${a.title||a.id}" loading="lazy">`
                        : `<div class="doc-card-placeholder"><span>${a.title||a.id}</span></div>`;
                    return `<div class="doc-card" onclick="location.href='/read/${a.id}'">
                        ${coverHtml}
                        <div class="doc-card-info">
                            <div class="doc-card-title">${a.title||a.id}</div>
                            <div class="doc-card-meta"><span>${(a.authors||[])[0]||''}</span><span>#${a.number}</span></div>
                        </div>
                    </div>`;
                }).join('')}</div></div>
            `;
        }

        async function updateNotiBadge(customCount) {
            if (!currentUser) return;
            const cnt = customCount !== undefined ? customCount : (await authFetch('/api/notifications/count', { headers: { 'X-Username': currentUser.username } }).then(r=>r.json())).count;
            const badge = document.getElementById('notiBadge');
            badge.textContent = cnt || 0;
            badge.style.display = cnt > 0 ? 'flex' : 'none';
        }
        function updateMsgBadge() { updateNotiBadge(); }

        async function loadNotifications() {
            if (!currentUser) return;
            const res = await authFetch('/api/notifications', { headers: { 'X-Username': currentUser.username } });
            const notis = await res.json();
            document.getElementById('notiList').innerHTML = notis.length ? notis.map(n => `
                <div class="noti-item ${n.read?'':'unread'}" onclick="markReadAndGo('${n.id}','${n.doc_id}','${n.comment_id||''}')">
                    ${n.from_avatar ? `<img src="/avatars/${n.from_avatar}" class="noti-avatar">` : `<div class="noti-avatar">${n.from_user?.charAt(0)||'?'}</div>`}
                    <div class="noti-content"><strong>${n.from_user}</strong> ${n.type==='reply'?'回复了你':'赞了你的评论'}<div>${n.content||''}</div><div class="noti-time">${new Date(n.timestamp).toLocaleString()}</div></div>
                </div>`).join('') : '<div class="noti-empty">暂无通知</div>';
        }

        window.toggleNotiDropdown = () => {
            const dd = document.getElementById('notiDropdown');
            if (dd.style.display === 'block') dd.style.display = 'none';
            else { loadNotifications(); dd.style.display = 'block'; }
        };

        window.markAllRead = async () => {
            if (!currentUser) return;
            await authFetch('/api/notifications/read', { method: 'POST', headers: { 'X-Username': currentUser.username } });
            updateNotiBadge(0);
            loadNotifications();
        };

        window.markReadAndGo = async (notiId, docId, commentId) => {
            if (currentUser && notiId) {
                let readList = JSON.parse(localStorage.getItem('readNotis')||'[]');
                if (!readList.includes(notiId)) { readList.push(notiId); localStorage.setItem('readNotis', JSON.stringify(readList)); }
                updateMsgBadge();
            }
            if (docId) window.location.href = commentId ? `/read/${docId}#comment-${commentId}` : `/read/${docId}`;
        };

        function showToast(title, content) {
            const toast = document.createElement('div');
            toast.style.cssText = 'position:fixed;top:20px;right:20px;background:var(--card-bg);border:1px solid var(--border);border-radius:8px;padding:12px 16px;box-shadow:var(--shadow);z-index:9999;animation:toastSlideIn .3s ease';
            toast.innerHTML = `<strong style="color:var(--primary)">${title}</strong><div>${content}</div>`;
            document.body.appendChild(toast);
            setTimeout(() => { toast.style.animation='toastSlideOut .3s ease'; setTimeout(()=>toast.remove(),300); }, 3000);
        }

        checkLogin();
    
        function hideLoadingOverlay() {
            hideRequested = true;
            const elapsed = Date.now() - PAGE_LOAD_TIME;
            const remaining = Math.max(0, 1000 - elapsed);
            setTimeout(function() {
                const overlay = document.getElementById('loadingOverlay');
                if (!overlay || overlay.style.display === 'none') return;
                overlay.style.opacity = "0";
                setTimeout(function() { overlay.style.display = "none"; }, 300);
            }, remaining);
        }

        let searchTimer = null;
        function search() {
            clearTimeout(searchTimer);
            searchTimer = setTimeout(doSearch, 300);
        }
        async function doSearch() {
            const q = document.getElementById('searchInput').value.trim();
            if (!q) { loadDocList(); return; }
            const isUser = q.startsWith('@');
            if (isUser) {
                const username = q.slice(1).trim();
                if (!username) return;
                window.location.href = '/user/' + encodeURIComponent(username);
                return;
            }
            const list = document.getElementById('docList');
            list.innerHTML = '<p>搜索中...</p>';
            try {
                const res = await authFetch('/api/search?q=' + encodeURIComponent(q));
                const results = await res.json();
                if (results.length === 0) {
                    list.innerHTML = '<p>未找到相关文章</p>';
                } else {
                    list.innerHTML = results.map(item => {
                        const title = item.title || item.id;
                        const author = (item.authors || [])[0] || '';
                        const cover = item.cover || '';
                        const coverHtml = cover
                            ? `<img class="doc-card-img" src="${cover}" alt="${title}" loading="lazy">`
                            : `<div class="doc-card-placeholder"><span>${title}</span></div>`;
                        return `<div class="doc-card" onclick="location.href='/read/${item.id}'">
                            ${coverHtml}
                            <div class="doc-card-info">
                                <div class="doc-card-title">${title}</div>
                                <div class="doc-card-meta"><span>${author}</span><span>#${item.number}</span></div>
                            </div>
                        </div>`;
                    }).join('');
                }
            } catch(e) {
                list.innerHTML = '<p style="color:red;">搜索失败，请重试</p>';
            }
        }
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('searchInput');
            if (searchInput) {
                searchInput.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter') { clearTimeout(searchTimer); doSearch(); }
                });
            }
        });

        function uploadAvatar(input) {
            const file = input.files[0];
            if (!file) return;
            const formData = new FormData();
            formData.append('avatar', file);
            authFetch('/api/upload_avatar', { method: 'POST', body: formData })
            .then(res => res.json()).then(data => {
                if (data.status === 'ok') {
                    currentUser.avatar = data.avatar;
                    localStorage.setItem('currentUser', JSON.stringify(currentUser));
                    loadProfile();
                    showToast('头像已更新');
                } else showToast(data.message || '上传失败');
            }).catch(() => showToast('上传失败'));
        }

        // Fallback: hide loader after 4s no matter what
        setTimeout(function() {
            hideLoadingOverlay();
        }, 4000);
        // ===== 合集相关 =====
    let collectionPickDocId = null;

    async function showCollectionPicker(docId) {
        if (!currentUser) { alert('请先登录'); return; }
        collectionPickDocId = docId;
        const modal = document.getElementById('collectionPickerModal');
        if (!modal) return;
        modal.style.display = 'flex';
        const list = document.getElementById('collectionPickerList');
        list.innerHTML = '<p>加载中...</p>';

        const res = await authFetch('/api/my_collections');
        const collections = await res.json();
        if (collections.length === 0) {
            list.innerHTML = `
                <p>你还没有创建合集</p>
                <div style="display:flex;gap:8px;">
                    <input id="newCollectionName" type="text" placeholder="合集名称" class="input" style="flex:1;padding:10px;border:1px solid var(--border);border-radius:8px;background:var(--card-bg);color:var(--text);">
                    <button class="basic-btn" onclick="createAndAddCollection()" style="white-space:nowrap;">+ 创建并加入</button>
                </div>
            `;
            return;
        }
        list.innerHTML = collections.map(c => `
            <div onclick="addToCollection('${c.id}')" style="padding:12px 16px; border:1px solid var(--border); border-radius:8px; margin-bottom:8px; cursor:pointer; transition:background 0.2s;" onmouseover="this.style.background='var(--card-bg)'" onmouseout="this.style.background='transparent'">
                <div style="font-weight:600;">${c.name}</div>
                <div style="font-size:0.85em; opacity:0.7;">${c.article_count || 0} 篇文章</div>
            </div>
        `).join('');
    }

    async function createAndAddCollection() {
        const name = document.getElementById('newCollectionName').value.trim();
        if (!name) { alert('请填写合集名称'); return; }
        const res = await authFetch('/api/collections', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name })
        });
        const data = await res.json();
        if (data.status === 'ok') {
            await addToCollection(data.collection_id);
        } else {
            alert(data.message || '创建失败');
        }
    }

    async function addToCollection(collectionId) {
        const docId = collectionPickDocId;
        if (!docId) return;
        const res = await authFetch('/api/collections/' + collectionId + '/articles', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ doc_id: docId })
        });
        const data = await res.json();
        if (data.status === 'ok') {
            showToast('已加入合集', '✅ 成功');
            document.getElementById('collectionPickerModal').style.display = 'none';
        } else {
            alert(data.message);
        }
    }
        
</script>
    <!-- 合集选择弹窗 -->
    <div class="modal" id="collectionPickerModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9998; justify-content:center; align-items:center;">
        <div style="background:var(--card-bg); padding:24px; border-radius:16px; max-width:400px; width:90%; max-height:80vh; overflow-y:auto;">
            <h3 style="margin-top:0;">添加到合集</h3>
            <div id="collectionPickerList"></div>
            <div style="margin-top:12px;">
                <button class="basic-btn" onclick="document.getElementById('collectionPickerModal').style.display='none'">取消</button>
            </div>
        </div>
    </div>
    <script>
    var pickerModal = document.getElementById('collectionPickerModal');
    if (pickerModal) {
        pickerModal.addEventListener('click', function(e) {
            if (e.target === this) this.style.display = 'none';
        });
    }
</script>
</body>
</html>
